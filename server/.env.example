# ----------------------------------------------------------------------------
# StudentConnect API — server environment variables
# Copy this file to `.env` and fill in real values for local development.
# In production (Render), set these in the dashboard, NOT in a committed file.
# ----------------------------------------------------------------------------

# Node environment: 'development' | 'test' | 'production'
NODE_ENV=development

# Port the Express server listens on
PORT=5001

# PostgreSQL connection string
# Local example: postgresql://<your-os-user>@localhost:5432/studentconnect
# Render injects this automatically when you bind a managed Postgres service.
DATABASE_URL=postgresql://jon@localhost:5432/studentconnect

# Optional: separate database used by `npm test` (CI uses this)
TEST_DATABASE_URL=postgresql://postgres:postgres@localhost:5432/studentconnect_test

# Secret used to sign JWT access tokens — MUST be a long random string in production
# Generate one with:  node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=replace-me-with-a-long-random-string

# Optional: API rate limit cap per IP per 15-minute window (default: 400)
# API_RATE_LIMIT_MAX=400

# Optional: comma-separated list of allowed CORS origins in production
# Example: https://studentconnect-app.onrender.com,https://studentconnect.app
# Leave unset in development to allow all origins.
# CORS_ORIGIN=
