# ----------------------------------------------------------------------------
# StudentConnect client — Vite environment variables
# Variables here are inlined into the build at build time.
# Copy to `.env.local` for local overrides (gitignored).
# ----------------------------------------------------------------------------

# Backend URL the dev server proxies /api and /uploads to.
# Default: http://localhost:5001 (chosen because macOS AirPlay grabs port 5000).
VITE_API_PROXY_TARGET=http://localhost:5001

# Production: absolute URL of the deployed API (used at runtime by client/src/api.js).
# Leave EMPTY in development — the Vite proxy handles routing then.
# Example: VITE_API_URL=https://studentconnect-api.onrender.com
VITE_API_URL=
